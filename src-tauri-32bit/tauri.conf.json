{
  "package": {
    "productName": "ltc-timecode-generator-32bit",
    "version": "0.1.0"
  },
  "build": {
    "distDir": "../dist",
    "devPath": "http://localhost:3000",
    "beforeDevCommand": "",
    "beforeBuildCommand": "",
    "withGlobalTauri": true
  },
  "tauri": {
    "bundle": {
      "active": true,
      "targets": "all",
      "identifier": "at.agere.ltc-timecode-generator-legacy",
      "icon": [
        "icons/32x32.png",
        "icons/128x128.png",
        "icons/icon.ico"
      ],
      "appimage": {
        "bundleMediaFramework": true
      }
    },
    "allowlist": {
      "all": true
    },
    "windows": [
      {
        "title": "LTC Timecode Generator",
        "width": 800,
        "height": 800
      }
    ]
  }
}
